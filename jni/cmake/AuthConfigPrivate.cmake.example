set(LENGJING_ENABLE_RUNTIME_AUTH ON CACHE BOOL "" FORCE)
set(LENGJING_AUTH_VERSION "1000" CACHE STRING "" FORCE)

set(LENGJING_T3_LOGIN_CODE "LOGIN_CODE" CACHE STRING "" FORCE)
set(LENGJING_T3_NOTICE_CODE "NOTICE_CODE" CACHE STRING "" FORCE)
set(LENGJING_T3_VERSION_CODE "VERSION_CODE" CACHE STRING "" FORCE)
set(LENGJING_T3_HEARTBEAT_CODE "HEARTBEAT_CODE" CACHE STRING "" FORCE)
set(LENGJING_T3_APP_KEY "APP_KEY" CACHE STRING "" FORCE)
set(LENGJING_T3_RSA_PUBLIC_KEY [=[PUBLIC_KEY]=] CACHE STRING "" FORCE)

set(LENGJING_T3_GET_VARIABLE_CODE "GET_VARIABLE_CODE" CACHE STRING "" FORCE)
set(LENGJING_T3_LAYOUT_VALUE_ID "VALUE_ID" CACHE STRING "" FORCE)
set(LENGJING_T3_LAYOUT_VALUE_NAME "VALUE_NAME" CACHE STRING "" FORCE)
set(LENGJING_T3_DECRYPT2_LAYOUT_VALUE_ID "DECRYPT2_VALUE_ID" CACHE STRING "" FORCE)
set(LENGJING_T3_DECRYPT2_LAYOUT_VALUE_NAME
    "coordinate_decrypt2_layout_v1" CACHE STRING "" FORCE)
set(LENGJING_T3_LAYOUT_PACKAGE "com.example.runtime" CACHE STRING "" FORCE)
set(LENGJING_T3_LAYOUT_MODULE "libTarget.so" CACHE STRING "" FORCE)
set(LENGJING_T3_LAYOUT_BUILD_ID
    "0123456789abcdef0123456789abcdef01234567"
    CACHE STRING "" FORCE)
